DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
PORT=3000

JWT_SECRET="change_me"
REGISTER_SECRET="change_me"

# Desenvolvimento local
FRONTEND_URL="http://localhost:5173"

# Produção (exemplo)
# FRONTEND_URL="https://auroralis.vercel.app"

# CORS - localhost sempre permitido; produção via CORS_ORIGIN ou CORS_ORIGIN_REGEX
CORS_ORIGIN="http://localhost:5173"
# Para produção: CORS_ORIGIN="https://auroralis.vercel.app"
# Regex para qualquer subdomínio Vercel: CORS_ORIGIN_REGEX="https://.*\\.vercel\\.app$"
CORS_ORIGIN_REGEX="https://.*\\.vercel\\.app$"

EMAIL_FROM="Aurora System <no-reply@example.com>"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your_email@example.com"
SMTP_PASS="your_email_password"
