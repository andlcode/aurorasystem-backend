generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  COORDENADOR
  EVANGELIZADOR
}

enum UserStatus {
  active
  inactive
}

enum ParticipantStatus {
  active
  inactive
}

enum AttendanceStatus {
  present
  absent
  justified
}

enum ClassParticipantStatus {
  active
  inactive
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String?
  username     String     @unique
  passwordHash String
  role         UserRole   @default(EVANGELIZADOR)
  status       UserStatus @default(active)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  responsibleClasses  Class[]             @relation("ClassResponsible")
  createdSessions     ClassSession[]
  recordedAttendances Attendance[]
  passwordResetTokens PasswordResetToken[]

  @@index([username])
  @@index([email])
  @@index([status])
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Participant {
  id        String            @id @default(uuid())
  name      String
  email     String?
  phone     String?
  status    ParticipantStatus @default(active)
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  classParticipants ClassParticipant[]
  attendances        Attendance[]

  @@index([name])
  @@index([email])
  @@index([status])
}

model Class {
  id                String   @id @default(uuid())
  name              String
  day               Int
  time              String
  responsibleUserId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  responsible  User             @relation("ClassResponsible", fields: [responsibleUserId], references: [id])
  participants ClassParticipant[]
  sessions     ClassSession[]

  @@index([responsibleUserId])
}

model ClassParticipant {
  id            String               @id @default(uuid())
  classId       String
  participantId String
  status        ClassParticipantStatus @default(active)
  startDate     DateTime             @default(now())
  endDate       DateTime?
  createdAt     DateTime             @default(now())

  class_      Class      @relation(fields: [classId], references: [id], onDelete: Restrict)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Restrict)

  @@index([classId])
  @@index([participantId])
  @@index([classId, status])
  @@index([participantId, status])
}

model ClassSession {
  id          String   @id @default(uuid())
  classId     String
  sessionDate DateTime @db.Date
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class_     Class       @relation(fields: [classId], references: [id], onDelete: Restrict)
  creator    User        @relation(fields: [createdBy], references: [id])
  attendances Attendance[]

  @@unique([classId, sessionDate])
  @@index([classId])
  @@index([sessionDate])
}

model Attendance {
  id                  String           @id @default(uuid())
  sessionId           String
  participantId       String
  status              AttendanceStatus
  justificationReason String?
  recordedBy          String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  session     ClassSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Restrict)
  recorder    User         @relation(fields: [recordedBy], references: [id])

  @@unique([sessionId, participantId])
  @@index([sessionId])
  @@index([participantId])
}
